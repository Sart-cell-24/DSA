question 3:
pattern:
A
AB
ABC
ABCD
ABCDE
 #include <stdio.h>

int main() {
    int n = 5;

    for (int i = 1; i <= n; i++) {
        for (char ch = 'A'; ch < 'A' + i; ch++) {
            printf("%c", ch);
        }
        printf("\n");
    }

    return 0;
} 
